{
  "name": "@johntdowney/ng-masontree-workspace",
  "description": "Workspace wrapper for an Angular rectangle-packing layout component backed by functional red-black trees",
  "author": "John T. Downey",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build ng-masontree",
    "watch": "ng build ng-masontree --watch --configuration development",
    "build-preview": "ng build ng-masontree-preview --configuration production",
    "test": "ng test",
    "publish": "npm run build && cd dist/ng-masontree && npm publish"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.12",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@johntdowney/masontree": "^1.1.5",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "resize-observer-polyfill": "^1.5.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}

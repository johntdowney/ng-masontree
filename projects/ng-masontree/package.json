  "license": "MIT",
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@johntdowney/masontree": "^1.0.13"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johntdowney/ng-masontree.git"
  },
  "module": "fesm2022/johntdowney-ng-masontree.mjs",
